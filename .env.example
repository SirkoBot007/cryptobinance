# ============================================================
# CRYPTOBINANCE — Variables de entorno
# Copia este archivo como .env.local y rellena los valores
# NUNCA subas .env.local a GitHub
# ============================================================

# --- SITE ---
NEXT_PUBLIC_SITE_URL=https://cryptobinance.vercel.app

# --- NOTION (CMS de contenido) ---
# Obtìn tu token en: https://www.notion.so/my-integrations
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_ARTICLES_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_KEYWORDS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_METRICS_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- REVALIDACIÓN (n8n webhook secret) ---
# Genera una cadena aleatoria segura, por ejemplo: openssl rand -hex 32
REVALIDATE_SECRET=cambia_esto_por_una_clave_segura_aleatoria

# --- GOOGLE ANALYTICS 4 (se añade en Fase 7-MON) ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# --- GOOGLE TAG MANAGER (se añade en Fase 7-MON) ---
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX

# --- ADSENSE (se añade cuando sea aprobado) ---
NEXT_PUBLIC_ADSENSE_PUBLISHER_ID=pub-xxxxxxxxxxxxxxxx
